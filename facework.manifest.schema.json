{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://facework.dev/schemas/facework.manifest.schema.json",
  "title": "Facework Manifest",
  "description": "Schema for Facework Protocol v1 project manifests. v1.1.0 adds runtime_ports; v1.2.0 adds HarnessBundle; v1.3.0 adds DesignInfrastructure; v1.4.0 adds optional efficiency hints + skill semantics polish (sponsors, verifier_skill_id, multiplayer, sensors/actuators, cache_affinity, load_mode, intermediate, compactable, model_tier, advisor_escalation).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "project",
    "inputs",
    "artifacts",
    "gates",
    "compliance"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^1\\.\\d+\\.\\d+$",
      "description": "1.0.0 (v0.0.4 baseline), 1.1.0 (v0.0.5 Runtime Ports), 1.2.0 (v0.0.6 HarnessBundle), 1.3.0 (v0.0.7 DesignInfrastructure), 1.4.0 (v0.0.8 efficiency hints + skill polish), and forward 1.x.x compatible."
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "domain",
        "stage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "enum": [
            "mvp",
            "beta",
            "scale"
          ]
        },
        "evidence_level": {
          "type": "string",
          "enum": [
            "validated",
            "signaled",
            "thesis"
          ],
          "description": "Demand evidence level from PROTOCOL.md §3. Calibrates artifact production depth and runtime_ports conformance (Validated=MUST, Signaled=SHOULD, Thesis=MAY-minimal)."
        },
        "track": {
          "type": "string",
          "enum": [
            "creator",
            "cultural_brand",
            "athlete",
            "agency_studio",
            "platform_product"
          ],
          "description": "Project track from PROTOCOL.md §3. Determines track-aware port skeleton defaults."
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "hunch"
      ],
      "properties": {
        "hunch": {
          "type": "string",
          "minLength": 1
        },
        "audience_context": {
          "type": "string"
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_thesis",
        "audience_field_map",
        "taste_contract",
        "decision_ledger",
        "wedge_spec",
        "system_architecture",
        "workflow_playbooks",
        "launch_plan",
        "sovereignty_map",
        "diagnostic_report"
      ],
      "properties": {
        "signal_thesis": { "type": "string", "minLength": 1 },
        "audience_field_map": { "type": "string", "minLength": 1 },
        "taste_contract": { "type": "string", "minLength": 1 },
        "decision_ledger": { "type": "string", "minLength": 1 },
        "wedge_spec": { "type": "string", "minLength": 1 },
        "system_architecture": { "type": "string", "minLength": 1 },
        "workflow_playbooks": { "type": "string", "minLength": 1 },
        "launch_plan": { "type": "string", "minLength": 1 },
        "sovereignty_map": { "type": "string", "minLength": 1 },
        "diagnostic_report": { "type": "string", "minLength": 1 }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantics",
        "field",
        "taste",
        "strategy",
        "architecture",
        "launch",
        "sovereignty",
        "diagnostic"
      ],
      "properties": {
        "semantics": { "$ref": "#/$defs/gateStatus" },
        "field": { "$ref": "#/$defs/gateStatus" },
        "taste": { "$ref": "#/$defs/gateStatus" },
        "strategy": { "$ref": "#/$defs/gateStatus" },
        "architecture": { "$ref": "#/$defs/gateStatus" },
        "launch": { "$ref": "#/$defs/gateStatus" },
        "sovereignty": { "$ref": "#/$defs/gateStatus" },
        "diagnostic": { "$ref": "#/$defs/gateStatus" }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_integrity",
        "taste_fidelity",
        "system_coherence",
        "operational_readiness",
        "infrastructure_sovereignty",
        "total",
        "level"
      ],
      "properties": {
        "signal_integrity": { "$ref": "#/$defs/score20" },
        "taste_fidelity": { "$ref": "#/$defs/score20" },
        "system_coherence": { "$ref": "#/$defs/score20" },
        "operational_readiness": { "$ref": "#/$defs/score20" },
        "infrastructure_sovereignty": { "$ref": "#/$defs/score20" },
        "total": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "type": "string",
          "enum": [
            "L0 Draft",
            "L1 Structured",
            "L2 Coherent",
            "L3 Launch-Ready",
            "L4 Sovereign"
          ]
        }
      }
    },
    "runtime_ports": {
      "$ref": "#/$defs/runtimePorts",
      "description": "Optional v1.1.0 block declaring the four runtime port manifest paths. Conformance per evidence_level: Validated=MUST, Signaled=SHOULD, Thesis=MAY (minimal SkillManifest only)."
    },
    "design_infrastructure": {
      "$ref": "#/$defs/designInfrastructureRef",
      "description": "Optional v1.3.0 block declaring tokens, components, examples, and evaluator skill ID. Conformance is track-aware (see PROTOCOL.md §11.7) — Cultural Brand MUST, Creator/Athlete/Platform SHOULD, Agency/Studio MAY."
    }
  },
  "$defs": {
    "gateStatus": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "score20": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    },
    "runtimePorts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills":      { "$ref": "#/$defs/runtimePortRef" },
        "memory":      { "$ref": "#/$defs/runtimePortRef" },
        "context":     { "$ref": "#/$defs/runtimePortRef" },
        "connections": { "$ref": "#/$defs/runtimePortRef" },
        "bundle":      { "$ref": "#/$defs/harnessBundleRef" }
      }
    },
    "harnessBundleRef": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to the harness-bundle/ directory (v1.2.0)."
        },
        "cache_affinity": {
          "type": "string",
          "enum": ["stable", "dynamic"],
          "default": "stable",
          "description": "v1.4.0 — Cache affinity hint for the bundle. Default 'stable'."
        }
      }
    },
    "designInfrastructureRef": {
      "type": "object",
      "required": ["tokens", "components", "examples", "evaluator_skill_id"],
      "additionalProperties": false,
      "properties": {
        "tokens": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to tokens.json (or .yaml)."
        },
        "components": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to components.yaml."
        },
        "examples": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to the examples/ directory."
        },
        "evaluator_skill_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Skill ID in SkillManifest that implements the design-eye evaluator."
        }
      }
    },
    "runtimePortRef": {
      "type": "object",
      "required": ["manifest"],
      "additionalProperties": true,
      "properties": {
        "manifest": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to the port manifest YAML file."
        },
        "cache_affinity": {
          "type": "string",
          "enum": ["stable", "dynamic"],
          "default": "stable",
          "description": "v1.4.0 — Cache affinity hint for the entire port manifest. Default 'stable'."
        }
      }
    },

    "skillManifest": {
      "type": "object",
      "required": ["version", "tenant", "track", "skills"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "tenant":  { "type": "string", "minLength": 1 },
        "track": {
          "type": "string",
          "enum": ["creator", "cultural_brand", "athlete", "agency_studio", "platform_product"]
        },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill" }
        }
      }
    },
    "skill": {
      "type": "object",
      "required": ["id", "name", "description", "domain", "trigger", "ownership", "playbook"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "name":        { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "domain":      { "type": "string", "minLength": 1 },
        "trigger":     { "enum": ["on_demand", "scheduled", "event", "continuous"] },
        "ownership":   { "enum": ["human", "agent", "hybrid"] },
        "playbook":    { "type": "string", "minLength": 1 },
        "inputs":      { "type": "array", "items": { "$ref": "#/$defs/skillParameter" } },
        "outputs":     { "type": "array", "items": { "$ref": "#/$defs/skillOutput" } },
        "depends_on_capabilities": { "type": "array", "items": { "type": "string" } },
        "reads_memory":  { "type": "array", "items": { "type": "string" } },
        "writes_memory": { "type": "array", "items": { "type": "string" } },
        "context_load":  { "type": "array", "items": { "type": "string" } },
        "integrations":  { "type": "array", "items": { "type": "string" } },
        "escalation":    { "type": "string" },
        "schedule":      { "type": "string" },
        "event": {
          "type": "object",
          "required": ["name", "source"],
          "properties": {
            "name":   { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "sponsors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "v1.4.0 — Human(s) accountable for the skill's correctness, memory hygiene, and lifecycle. SHOULD be populated on Validated-evidence projects."
        },
        "verifier_skill_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "v1.4.0 — ID of a Skill (in the same manifest) that gates this skill's output before publication. The verifier SHOULD have domain: quality. Generalizes the design-eye-evaluator pattern (PROTOCOL.md §11)."
        },
        "multiplayer": {
          "type": "boolean",
          "default": false,
          "description": "v1.4.0 — When true, the skill may be invoked by multiple users concurrently and memory writes accrue across users. Default false (single-user)."
        },
        "model_tier": {
          "type": "string",
          "enum": ["standard", "advanced"],
          "default": "standard",
          "description": "v1.4.0 — Declares which model tier this skill warrants. Runtimes map 'advanced' to their premium tier (e.g. Opus). Default 'standard'."
        },
        "advisor_escalation": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "v1.4.0 — Optional skill_id that this skill can invoke for a one-shot advisor judgment on advanced model_tier. Composable: the escalation goes through a registered Skill, so it gets its own audit trail."
        }
      },
      "allOf": [
        { "if": { "properties": { "trigger": { "const": "scheduled" } } },
          "then": { "required": ["schedule"] } },
        { "if": { "properties": { "trigger": { "const": "event" } } },
          "then": { "required": ["event"] } }
      ]
    },
    "skillParameter": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "type":        { "enum": ["string", "number", "boolean", "object", "array", "file_path", "url"] },
        "required":    { "type": "boolean" },
        "description": { "type": "string" }
      }
    },
    "skillOutput": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "type":        { "enum": ["string", "number", "boolean", "object", "array", "file_path", "url"] },
        "write_to":    { "type": "string" },
        "description": { "type": "string" },
        "intermediate": {
          "type": "boolean",
          "default": false,
          "description": "v1.4.0 — When true, the output exists for downstream tool consumption only. Runtimes may keep it out of the operator's context window. Default false (visible)."
        }
      }
    },

    "memoryMap": {
      "type": "object",
      "required": ["version", "tenant", "root", "structure", "boundary"],
      "additionalProperties": false,
      "properties": {
        "version":   { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "tenant":    { "type": "string", "minLength": 1 },
        "root":      { "type": "string", "minLength": 1, "not": { "pattern": "^/" } },
        "structure": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/memoryFolder" } },
        "indexing":  { "type": "array", "items": { "$ref": "#/$defs/memoryIndex" } },
        "boundary":  { "$ref": "#/$defs/memoryBoundary" },
        "retention": { "type": "array", "items": { "$ref": "#/$defs/memoryRetention" } },
        "conventions": { "type": "object", "additionalProperties": true }
      }
    },
    "memoryFolder": {
      "type": "object",
      "required": ["path", "purpose"],
      "additionalProperties": false,
      "properties": {
        "path":       { "type": "string", "minLength": 1 },
        "purpose":    { "type": "string", "minLength": 1 },
        "contains":   { "type": "array", "items": { "type": "string" } },
        "written_by": { "type": "array", "items": { "type": "string" } },
        "read_by":    { "type": "array", "items": { "type": "string" } },
        "children":   { "type": "array", "items": { "$ref": "#/$defs/memoryFolder" } },
        "compactable": {
          "type": "boolean",
          "default": false,
          "description": "v1.4.0 — When true, the folder's contents may be summarized or dropped from in-session context after writing. Content persists on disk. Default false (kept in context)."
        }
      }
    },
    "memoryBoundary": {
      "type": "object",
      "required": ["tenant_memory_root", "runtime_memory_path", "rule"],
      "additionalProperties": false,
      "properties": {
        "tenant_memory_root":  { "type": "string", "minLength": 1 },
        "runtime_memory_path": { "type": "string", "minLength": 1 },
        "rule":                { "type": "string", "minLength": 1 },
        "responsibilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tenant_memory":  { "type": "array", "items": { "type": "string" } },
            "runtime_memory": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "memoryIndex": {
      "type": "object",
      "required": ["folder", "tool"],
      "additionalProperties": false,
      "properties": {
        "folder":          { "type": "string", "minLength": 1 },
        "tool":            { "type": "string", "minLength": 1 },
        "scope":           { "enum": ["recursive", "direct"] },
        "refresh":         { "enum": ["on_write", "scheduled", "manual"] },
        "refresh_schedule": { "type": "string" }
      },
      "allOf": [
        { "if": { "properties": { "refresh": { "const": "scheduled" } } },
          "then": { "required": ["refresh_schedule"] } }
      ]
    },
    "memoryRetention": {
      "type": "object",
      "required": ["path", "policy"],
      "additionalProperties": false,
      "properties": {
        "path":   { "type": "string", "minLength": 1 },
        "policy": { "enum": ["keep_forever", "archive_after_days", "delete_after_days", "compress_after_days"] },
        "days":   { "type": "integer", "minimum": 1 },
        "target": { "type": "string" }
      },
      "allOf": [
        { "if": { "properties": { "policy": { "enum": ["archive_after_days", "delete_after_days", "compress_after_days"] } } },
          "then": { "required": ["days"] } }
      ]
    },

    "contextManifest": {
      "type": "object",
      "required": ["version", "tenant", "global", "bundles"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "tenant":  { "type": "string", "minLength": 1 },
        "global":  { "$ref": "#/$defs/contextBundle" },
        "bundles": { "type": "array", "items": { "$ref": "#/$defs/contextBundle" } }
      }
    },
    "contextBundle": {
      "type": "object",
      "required": ["id", "name", "purpose"],
      "additionalProperties": false,
      "properties": {
        "id":         { "type": "string", "pattern": "^[a-z_][a-z0-9_-]*$" },
        "name":       { "type": "string", "minLength": 1 },
        "purpose":    { "type": "string", "minLength": 1 },
        "load":       { "type": "array", "items": { "$ref": "#/$defs/contextSource" } },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "priority":   { "enum": ["must", "should", "may"] },
        "composes":   { "type": "array", "items": { "type": "string" } },
        "excludes":   { "type": "array", "items": { "type": "string" } },
        "cache_affinity": {
          "type": "string",
          "enum": ["stable", "dynamic"],
          "default": "stable",
          "description": "v1.4.0 — Runtimes implementing prompt caching use this to inform eviction strategy. Default 'stable' (cache aggressively)."
        }
      },
      "anyOf": [
        { "properties": { "load":     { "type": "array", "minItems": 1 } }, "required": ["load"] },
        { "properties": { "composes": { "type": "array", "minItems": 1 } }, "required": ["composes"] }
      ]
    },
    "contextSource": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind":        { "enum": ["file", "query", "live", "section"] },
        "path":        { "type": "string" },
        "query":       { "type": "string" },
        "against":     { "type": "string" },
        "integration": { "type": "string" },
        "section":     { "type": "string" },
        "format":      { "enum": ["markdown", "yaml", "json", "text"] },
        "as":          { "enum": ["system_prompt", "tool_result", "file", "inline"] },
        "description": { "type": "string" }
      },
      "allOf": [
        { "if": { "properties": { "kind": { "const": "file" } } },
          "then": { "required": ["path"] } },
        { "if": { "properties": { "kind": { "const": "query" } } },
          "then": { "required": ["query", "against"] } },
        { "if": { "properties": { "kind": { "const": "live" } } },
          "then": { "required": ["integration"] } },
        { "if": { "properties": { "kind": { "const": "section" } } },
          "then": { "required": ["path", "section"] } }
      ]
    },

    "integrationManifest": {
      "type": "object",
      "required": ["version", "tenant", "integrations"],
      "additionalProperties": false,
      "properties": {
        "version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "tenant":       { "type": "string", "minLength": 1 },
        "integrations": { "type": "array", "items": { "$ref": "#/$defs/integration" } }
      }
    },
    "integration": {
      "type": "object",
      "required": ["id", "name", "kind", "auth", "trust_boundary", "used_by"],
      "additionalProperties": false,
      "properties": {
        "id":              { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "name":            { "type": "string", "minLength": 1 },
        "kind":            { "enum": ["mcp", "rest", "cli", "filesystem", "webhook", "db"] },
        "auth":            { "enum": ["oauth", "api_key", "local", "none", "mtls"] },
        "trust_boundary":  { "enum": ["own", "rent", "mitigate"] },
        "used_by":         { "type": "array", "items": { "type": "string" } },
        "endpoint":        { "type": "string" },
        "scope":           {
          "type": "array",
          "items": { "$ref": "#/$defs/integrationScopeItem" },
          "description": "v1.4.0 — Each item is either a string (operation name, back-compat with v1.0.0–v1.3.0) OR an object {operation, direction}. Mixed forms allowed."
        },
        "secrets":         { "type": "array", "items": { "$ref": "#/$defs/secretRef" } },
        "rate_limits":     { "type": "object", "additionalProperties": true },
        "failover":        { "type": "string" },
        "data_residency":  { "type": "string" },
        "pii":             { "type": "boolean" },
        "description":     { "type": "string" },
        "load_mode": {
          "type": "string",
          "enum": ["eager", "lazy", "on_search"],
          "default": "eager",
          "description": "v1.4.0 — Declares whether the runtime should eagerly load the integration's schema/handles or pull on demand. Default 'eager'. 'on_search' maps to Claude Platform tool-search optimization."
        }
      },
      "allOf": [
        { "if": { "properties": { "pii": { "const": true } } },
          "then": { "required": ["data_residency"] } }
      ]
    },
    "secretRef": {
      "type": "object",
      "required": ["name", "store", "ref"],
      "additionalProperties": false,
      "properties": {
        "name":     { "type": "string", "minLength": 1 },
        "store":    { "type": "string", "minLength": 1 },
        "ref":      { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" }
      }
    },
    "integrationScopeItem": {
      "description": "v1.4.0 — Scope items may be either a plain operation string (back-compat) or an object with operation + direction (sensors/actuators framing from Karpathy).",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["operation"],
          "additionalProperties": false,
          "properties": {
            "operation": { "type": "string", "minLength": 1 },
            "direction": {
              "type": "string",
              "enum": ["sensor", "actuator", "both"],
              "description": "sensor = reads from external world; actuator = writes/acts on external world; both = bidirectional."
            }
          }
        }
      ]
    }
  }
}
